# =============================================================================
# AffKit Frontend — Environment Variables
# Copy file này thành .env.local và điền giá trị thật
# =============================================================================

# Backend API (Spring Boot đang chạy local)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Frontend app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Short URL base (backend xử lý redirect)
NEXT_PUBLIC_SHORT_URL_BASE=http://localhost:8080/go
